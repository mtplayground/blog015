# SQLite database connection string used by Prisma
DATABASE_URL="file:./dev.db"

# Admin dashboard password used for login validation
# Use a strong unique value in non-development environments
ADMIN_PASSWORD="change-this-admin-password"

# Secret key used to sign/verify session cookies
# Generate a long random string (32+ chars)
SESSION_SECRET="change-this-to-a-long-random-secret"

# Public base URL for metadata, links, and redirects
# Examples: http://localhost:8080 (dev), https://example.com (prod)
BASE_URL="http://localhost:8080"
